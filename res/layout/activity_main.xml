<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F7FA">

    <TextView
        android:id="@+id/header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cakru Logic"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#2D3436"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_title"
        android:text="High-Performance Rust Engine"
        android:textSize="14sp"
        android:textColor="#636E72"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/input_teks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/sub_title"
        android:hint="Masukkan perintah ke Rust..."
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:elevation="2dp"
        android:inputType="text"
        android:minHeight="56dp" />

    <Button
        android:id="@+id/btn_proses"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@id/input_teks"
        android:layout_marginTop="20dp"
        android:text="PROSES DI RUST"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0984E3"
        android:elevation="4dp" />

    <TextView
        android:id="@+id/label_hasil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btn_proses"
        android:layout_marginTop="40dp"
        android:text="HASIL EKSEKUSI:"
        android:textSize="12sp"
        android:letterSpacing="0.1"
        android:textColor="#B2BEC3" />

    <TextView
        android:id="@+id/hasil_rust"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/label_hasil"
        android:layout_marginTop="8dp"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:text="Menunggu input..."
        android:textSize="18sp"
        android:textColor="#2D3436"
        android:elevation="2dp"
        android:lineSpacingExtra="4dp" />

</RelativeLayout>
