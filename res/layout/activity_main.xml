<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:padding="16dp">

    <RelativeLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcru AI"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Pilih Model" />
    </RelativeLayout>

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_bar"
        android:layout_above="@+id/input_container"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="2dp"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:id="@+id/output_ai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Menunggu Model...\nKlik ikon gear untuk memilih file .gguf"
            android:textSize="16sp"
            android:textColor="#333333" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:elevation="4dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/input_ai"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Tanya sesuatu..."
            android:background="@android:color/transparent"
            android:padding="10dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btn_kirim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kirim"
            android:backgroundTint="#1A237E"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</RelativeLayout>
